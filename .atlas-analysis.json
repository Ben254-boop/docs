  "keyFeatures": [
    "Separate Admin and User interfaces with role-based access control",
    "Admin-managed user account creation and login credentials",
    "Modern, responsive dashboard with real-time inventory statistics",
    "Full inventory CRUD — add, edit, delete, and track stock items",
    "Category and department-based item organization",
    "Stock request and approval workflow for users",
    "Low-stock alerts and inventory notifications",
    "Advanced search and filter across inventory records",
    "Printable and exportable inventory reports",
    "Built with HTML, CSS, PHP, and MySQL — no external frameworks"
  ],
